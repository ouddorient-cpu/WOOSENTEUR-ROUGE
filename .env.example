# -----------------------------------------------------------------------------
# FICHIER D'EXEMPLE POUR LES VARIABLES D'ENVIRONNEMENT
# -----------------------------------------------------------------------------
# 1. Copiez ce fichier et renommez la copie en ".env".
# 2. Remplissez les valeurs ci-dessous avec vos propres clés API.
# 3. N'oubliez pas de redémarrer votre serveur de développement après modification.
# -----------------------------------------------------------------------------

# Google AI - Pour la génération de contenu par IA (Gemini).
# Requis pour la fonctionnalité principale de génération.
# Obtenez votre clé depuis Google AI Studio.
# Voir le guide : docs/SECURITY_SETUP.md
GOOGLE_GENAI_API_KEY="AIzaSy...votre_cle_api_gemini"

# Firebase Admin - Pour les opérations côté serveur (gestion des crédits, etc.).
# CRITIQUE pour les fonctionnalités liées aux utilisateurs après le paiement.
# Doit être une chaîne JSON sur une seule ligne.
# Obtenez cette clé depuis la console Firebase > Paramètres du projet > Comptes de service.
# Voir le guide : docs/SECURITY_SETUP.md
SERVICE_ACCOUNT_KEY='{"type":"service_account", "project_id": "...", ...}'

# Google Custom Search - Pour l'outil de recherche web qui vérifie l'existence des produits.
# Optionnel, mais recommandé pour de meilleurs résultats de l'IA.
# Voir le guide : docs/CONFIG_GOOGLE_SEARCH.md
GOOGLE_CUSTOM_SEARCH_API_KEY="AIzaSy...votre_cle_google_search"
GOOGLE_CUSTOM_SEARCH_ENGINE_ID="votre_id_de_moteur_de_recherche"

# Stripe - Pour les paiements et la gestion des abonnements.
# Requis si vous utilisez la page de tarification et les paiements.
# Obtenez ces clés depuis votre tableau de bord Stripe.
# Voir le guide : docs/STRIPE_FIREBASE_GUIDE.md
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY=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
STRIPE_WEBHOOK_SECRET=whsec_nO6menLvQ6Z4csQ9YguZn2CVCj3yASX8

# WooCommerce - Pour la publication directe des produits sur votre boutique.
# Remplissez ces clés dans votre profil utilisateur dans l'application.
# Il n'est généralement pas nécessaire de les mettre ici, sauf pour des tests.
# NEXT_PUBLIC_ADMIN_WOOCOMMERCE_STORE_URL="https://maboutique.com"
# NEXT_PUBLIC_ADMIN_WOOCOMMERCE_CONSUMER_KEY="ck_..."
# NEXT_PUBLIC_ADMIN_WOOCOMMERCE_CONSUMER_SECRET="cs_..."
