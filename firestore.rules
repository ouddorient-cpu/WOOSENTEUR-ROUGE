
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Customers and their checkout sessions, subscriptions, and payments
    // Managed by the Stripe extension
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;
      
      // checkout_sessions are created by the client, read by the extension
      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      // subscriptions are written by the extension, readable by the client
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
      match /payments/{id} {
        allow read: if request.auth.uid == uid;
      }
    }

    // Products and prices, readable by anyone
    // These are synced from your Stripe dashboard by the extension
    match /products/{id} {
      allow read: if true;
      allow write: if false;

      match /prices/{id} {
        allow read: if true;
        allow write: if false;
      }

      match /tax_rates/{id} {
        allow read: if true;
        allow write: if false;
      }
    }
    
    // User profiles - Your app's user data
    match /users/{userId} {
      allow get, update, delete: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
      allow create: if request.auth.uid == userId;
      allow list: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';

      // Products subcollection within users (your app's data)
      match /products/{productId} {
        allow read, write: if request.auth.uid == userId;
      }

      // Marketing campaigns subcollection
      match /campaigns/{campaignId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
  }
}
